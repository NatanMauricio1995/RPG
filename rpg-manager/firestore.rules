rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── Funções Auxiliares ──────────────────────────────────────────────────
    
    // Verifica se o usuário está autenticado e é o dono do documento
    function ehDono(data) {
      return request.auth != null && data.userId == request.auth.uid;
    }

    // ─── Coleções de Sistema (Públicas) ──────────────────────────────────────
    // Leitura permitida a todos, escrita restrita ao Admin (via Console ou SDK)
    match /classes/{id}     { allow read: if true; allow write: if false; }
    match /racas/{id}       { allow read: if true; allow write: if false; }
    match /habilidades/{id} { allow read: if true; allow write: if false; }
    match /itens/{id}       { allow read: if true; allow write: if false; }
    match /monstros/{id}    { allow read: if true; allow write: if false; }

    // ─── Coleções de Usuário/Campanha ─────────────────────────────────────────
    // Apenas o dono (userId == auth.uid) pode ler ou escrever
    
    match /personagens/{id} {
      allow read, write: if ehDono(resource.data) || ehDono(request.resource.data);
    }
    
    match /npcs/{id} {
      allow read, write: if ehDono(resource.data) || ehDono(request.resource.data);
    }
    
    match /missoes/{id} {
      allow read, write: if ehDono(resource.data) || ehDono(request.resource.data);
    }
    
    match /areas/{id} {
      allow read, write: if ehDono(resource.data) || ehDono(request.resource.data);
    }
    
    match /combates/{id} {
      allow read, write: if ehDono(resource.data) || ehDono(request.resource.data);
    }
    
    match /historico/{id} {
      allow read, write: if ehDono(resource.data) || ehDono(request.resource.data);
    }
    
    // Nota: Para histórico de combate consolidado (historicos_combate), 
    // se existir, deve seguir a mesma regra:
    match /historicos_combate/{id} {
      allow read, write: if ehDono(resource.data) || ehDono(request.resource.data);
    }
  }
}
