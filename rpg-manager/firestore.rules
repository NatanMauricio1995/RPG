rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /personagens/{id} {
      allow read: if true;
      allow write: if request.resource.data.nome is string
                   && request.resource.data.nome.size() > 0
                   && request.resource.data.atributosBase is map;
    }
    match /itens/{id} {
      allow read: if true;
      allow write: if request.resource.data.nome is string
                   && request.resource.data.tipo is string;
    }
    match /historicos_combate/{id} {
      allow read: if true;
      allow write: if request.resource.data.data is string
                   && request.resource.data.participantes is list;
    }
    match /{collection}/{id} {
      allow read: if true;
      allow write: if request.resource.data.nome is string
                   && request.resource.data.nome.size() > 0;
    }
  }
}
