rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Função auxiliar para verificar se o usuário é o dono
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /personagens/{id} {
      // Permite ler se for o dono. 
      // Nota: resource.data.userId para documentos existentes
      // Para queries, o filtro de userId deve estar presente
      allow read: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
      
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.nome is string
                    && request.resource.data.nome.size() > 0;
                    
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId;
                    
      allow delete: if isOwner(resource.data.userId);
    }

    match /itens/{id} {
      allow read: if true; // Catálogo é público
      allow write: if false; // Apenas admin (via console ou script)
    }

    match /historicos_combate/{id} {
      // Aqui assumimos que o histórico tem um campo userId
      allow read: if isOwner(resource.data.userId);
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Histórico é imutável
    }

    // Regras gerais para outras coleções (NPCs, Missões, Áreas)
    match /npcs/{id} { allow read: if true; allow write: if false; }
    match /missoes/{id} { allow read: if true; allow write: if false; }
    match /areas/{id} { allow read: if true; allow write: if false; }
    match /monstros/{id} { allow read: if true; allow write: if false; }
  }
}
