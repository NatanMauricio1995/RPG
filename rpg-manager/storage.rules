rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ─── Imagens de Perfil / Sistema ─────────────────────────────────────────
    match /imagens/{userId}/{fileName} {
      
      // Leitura pública para que avatares sejam visíveis a todos no sistema
      allow read: if true;
      
      // Escrita permitida apenas se:
      // 1. O usuário estiver autenticado
      // 2. O userId no caminho for igual ao UID do usuário
      // 3. O arquivo for uma imagem (PNG, JPEG, JPG)
      // 4. O tamanho for menor que 5MB
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(png|jpeg|jpg)');
    }
    
    // Arquivos globais de sistema (se existirem)
    match /sistema/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Apenas via console
    }
  }
}
